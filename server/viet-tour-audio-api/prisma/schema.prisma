generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  VENDOR
  MODERATOR
  FINANCE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AudioStatus {
  PENDING
  READY
  ERROR
}

enum ZoneType {
  LANDMARK
  RESTAURANT
  BAR
  SHOP
  OTHER
}

enum ActiveTime {
  ALL
  DAY
  NIGHT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  OVERDUE
  SUSPENDED
  CANCELLED
}

model User {
  id             Int               @id @default(autoincrement())
  username       String            @unique @db.VarChar(50)
  passwordHash   String            @db.VarChar(255)
  fullName       String?           @db.VarChar(100)
  email          String?           @unique @db.VarChar(120)
  phoneNumber    String?           @db.VarChar(20)
  role           UserRole          @default(VENDOR)
  shopId         Int?              @unique
  isActive       Boolean           @default(false)
  approvalStatus ApprovalStatus    @default(PENDING)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  shop           Shop?             @relation(fields: [shopId], references: [id])
  notifications  AppNotification[]
  auditLogs      AuditLog[]
}

model Shop {
  id               Int                  @id @default(autoincrement())
  name             String               @db.VarChar(120)
  slug             String?              @unique @db.VarChar(160)
  description      String?              @db.Text
  address          String?              @db.VarChar(255)
  phoneNumber      String?              @db.VarChar(20)
  imageUrl         String?              @db.VarChar(500)
  latitude         Decimal              @db.Decimal(10, 8)
  longitude        Decimal              @db.Decimal(11, 8)
  activationRadius Int                  @default(10)
  openStatus       Boolean              @default(true)
  isPremium        Boolean              @default(false)
  priorityWeight   Int                  @default(0)
  approvalStatus   ApprovalStatus       @default(PENDING)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  hours            ShopHour[]
  zones            Zone[]
  user             User?
  subscriptions    VendorSubscription[]
  mediaFiles       MediaFile[]
}

model ShopHour {
  id        Int     @id @default(autoincrement())
  shopId    Int
  dayOfWeek Int
  openTime  String? @db.VarChar(5)
  closeTime String? @db.VarChar(5)
  isClosed  Boolean @default(false)
  shop      Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, dayOfWeek])
}

model Zone {
  id           Int               @id @default(autoincrement())
  shopId       Int?
  name         String            @db.VarChar(120)
  description  String?           @db.Text
  imageUrl     String?           @db.VarChar(500)
  latitude     Decimal           @db.Decimal(10, 8)
  longitude    Decimal           @db.Decimal(11, 8)
  radius       Int               @default(10)
  orderIndex   Int               @default(0)
  zoneType     ZoneType          @default(LANDMARK)
  isPremium    Boolean           @default(false)
  isActive     Boolean           @default(true)
  isLocked     Boolean           @default(false)
  isHidden     Boolean           @default(false)
  lockReason   String?           @db.VarChar(500)
  activeTime   ActiveTime        @default(ALL)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  shop         Shop?             @relation(fields: [shopId], references: [id])
  translations ZoneTranslation[]
  narrations   Narration[]
  tourZones    TourZone[]
  analytics    Analytic[]
  favorites    GuestFavorite[]
  mediaFiles   MediaFile[]
}

model ZoneTranslation {
  id          Int      @id @default(autoincrement())
  zoneId      Int
  language    String   @db.VarChar(5)
  title       String?  @db.VarChar(200)
  description String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  zone        Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([zoneId, language])
}

model Narration {
  id              Int            @id @default(autoincrement())
  zoneId          Int
  language        String         @db.VarChar(5)
  text            String         @db.LongText
  voiceId         String?        @db.VarChar(80)
  fileUrl         String?        @db.VarChar(512)
  durationSeconds Int            @default(0)
  audioStatus     AudioStatus    @default(PENDING)
  approvalStatus  ApprovalStatus @default(PENDING)
  rejectReason    String?        @db.VarChar(500)
  updatedAt       DateTime       @updatedAt
  updatedById     Int?
  zone            Zone           @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([zoneId, language])
}

model Tour {
  id           Int               @id @default(autoincrement())
  name         String            @db.VarChar(200)
  slug         String?           @unique @db.VarChar(220)
  description  String?           @db.Text
  imageUrl     String?           @db.VarChar(500)
  duration     Int?
  priceAmount  Decimal           @default(30000) @db.Decimal(10, 2)
  currency     String            @default("VND") @db.VarChar(3)
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  translations TourTranslation[]
  tourZones    TourZone[]
}

model TourTranslation {
  id          Int      @id @default(autoincrement())
  tourId      Int
  language    String   @db.VarChar(5)
  name        String   @db.VarChar(200)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tour        Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, language])
}

model TourZone {
  tourId     Int
  zoneId     Int
  orderIndex Int  @default(0)
  tour       Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)
  zone       Zone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@id([tourId, zoneId])
}

model QrDeepLink {
  id           Int      @id @default(autoincrement())
  tokenHash    String   @unique @db.VarChar(128)
  tokenPreview String   @db.VarChar(16)
  targetType   String   @db.VarChar(20)
  targetId     Int
  label        String?  @db.VarChar(120)
  isActive     Boolean  @default(true)
  expiresAt    DateTime?
  maxUses      Int?
  currentUses  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model GuestFavorite {
  id        Int      @id @default(autoincrement())
  guestId   String   @db.VarChar(64)
  zoneId    Int
  createdAt DateTime @default(now())
  zone      Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([guestId, zoneId])
}

model Analytic {
  id               Int      @id @default(autoincrement())
  zoneId           Int?
  shopId           Int?
  tourId           Int?
  sessionId        String   @db.VarChar(64)
  guestId          String?  @db.VarChar(64)
  latitude         Decimal? @db.Decimal(10, 8)
  longitude        Decimal? @db.Decimal(11, 8)
  actionType       String   @db.VarChar(50)
  dwellTimeSeconds Int?
  language         String?  @db.VarChar(5)
  metadata         Json?
  createdAt        DateTime @default(now())
  zone             Zone?    @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  @@index([actionType, createdAt])
  @@index([zoneId, createdAt])
  @@index([shopId, createdAt])
}

model Payment {
  id             Int           @id @default(autoincrement())
  guestId        String?       @db.VarChar(64)
  sessionId      String?       @db.VarChar(64)
  shopId         Int?
  tourId         Int?
  paymentType    String        @db.VarChar(40)
  provider       String        @default("mock") @db.VarChar(30)
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("VND") @db.VarChar(3)
  status         PaymentStatus @default(PENDING)
  transactionRef String?       @unique @db.VarChar(255)
  paidAt         DateTime?
  expiresAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model SubscriptionPlan {
  id               Int                  @id @default(autoincrement())
  name             String               @db.VarChar(100)
  monthlyPrice     Decimal              @db.Decimal(12, 2)
  isPremium        Boolean              @default(false)
  maxZones         Int                  @default(3)
  maxImages        Int                  @default(10)
  maxAudioVariants Int                  @default(1)
  priorityWeight   Int                  @default(0)
  isActive         Boolean              @default(true)
  subscriptions    VendorSubscription[]
}

model VendorSubscription {
  id          Int                @id @default(autoincrement())
  shopId      Int
  planId      Int
  status      SubscriptionStatus @default(TRIAL)
  periodStart DateTime
  periodEnd   DateTime
  autoRenew   Boolean            @default(false)
  shop        Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  plan        SubscriptionPlan   @relation(fields: [planId], references: [id])

  @@index([shopId, status, periodEnd])
}

model MediaFile {
  id             Int      @id @default(autoincrement())
  ownerUserId    Int?
  shopId         Int?
  zoneId         Int?
  mediaType      String   @db.VarChar(20)
  storagePath    String   @db.VarChar(800)
  publicUrl      String   @db.VarChar(800)
  mimeType       String?  @db.VarChar(100)
  sizeBytes      Int      @default(0)
  checksumSha256 String?  @db.VarChar(64)
  createdAt      DateTime @default(now())
  shop           Shop?    @relation(fields: [shopId], references: [id], onDelete: SetNull)
  zone           Zone?    @relation(fields: [zoneId], references: [id], onDelete: SetNull)
}

model AppNotification {
  id              Int      @id @default(autoincrement())
  recipientUserId Int?
  recipientRole   String   @db.VarChar(20)
  message         String   @db.VarChar(500)
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())
  readAt          DateTime?
  user            User?    @relation(fields: [recipientUserId], references: [id], onDelete: SetNull)
}

model AppSetting {
  key       String   @id @db.VarChar(100)
  value     String?  @db.VarChar(500)
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  actorUserId Int?
  action      String   @db.VarChar(80)
  entityType  String   @db.VarChar(80)
  entityId    String?  @db.VarChar(80)
  reason      String?  @db.VarChar(500)
  beforeData  Json?
  afterData   Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
}
