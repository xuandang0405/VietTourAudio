// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ─── USERS & AUTH ───────────────────────────────────────────

model User {
  id           BigInt    @id @default(autoincrement())
  email        String    @unique @db.VarChar(255)
  phone        String?   @db.VarChar(30)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  displayName  String?   @map("display_name") @db.VarChar(255)
  role         UserRole  @default(ADMIN)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]     @relation("PerformedBy")
  approvedVendors Vendor[]       @relation("ApprovedBy")
  approvedMedia  MediaFile[]    @relation("ModeratedBy")

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  FINANCE
}

enum UserStatus {
  ACTIVE
  LOCKED
  DELETED
}

model RefreshToken {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  tokenHash String   @map("token_hash") @db.Char(64)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
  @@map("refresh_tokens")
}

// ─── VENDORS & STALLS ────────────────────────────────────────

model Vendor {
  id                 BigInt           @id @default(autoincrement())
  businessName       String           @map("business_name") @db.VarChar(255)
  contactPhone       String?          @map("contact_phone") @db.VarChar(30)
  ownerEmail         String           @map("owner_email") @db.VarChar(255)
  ownerDisplayName   String?          @map("owner_display_name") @db.VarChar(255)
  taxCode            String?          @map("tax_code") @db.VarChar(50)
  verificationStatus VendorStatus     @default(PENDING) @map("verification_status")
  rejectionReason    String?          @map("rejection_reason") @db.Text
  approvedById       BigInt?          @map("approved_by_id")
  approvedAt         DateTime?        @map("approved_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  approvedBy         User?            @relation("ApprovedBy", fields: [approvedById], references: [id])
  subscription       VendorSubscription?
  stalls             Stall[]
  payments           Payment[]
  commissions        CommissionEarning[]
  mediaFiles         MediaFile[]

  @@index([verificationStatus, createdAt])
  @@map("vendors")
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model SubscriptionPlan {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(100)
  monthlyPrice    Decimal  @map("monthly_price") @db.Decimal(12, 2)
  isPremium       Boolean  @default(false) @map("is_premium")
  maxPois         Int      @default(3) @map("max_pois")
  maxImages       Int      @default(10) @map("max_images")
  maxVideos       Int      @default(1) @map("max_videos")
  maxAudioVariants Int     @default(1) @map("max_audio_variants")
  priorityWeight  Int      @default(0) @map("priority_weight")
  isActive        Boolean  @default(true) @map("is_active")

  subscriptions   VendorSubscription[]

  @@map("subscription_plans")
}

model VendorSubscription {
  id          BigInt             @id @default(autoincrement())
  vendorId    BigInt             @unique @map("vendor_id")
  planId      Int                @map("plan_id")
  status      SubscriptionStatus @default(TRIAL)
  periodStart DateTime           @map("period_start") @db.Date
  periodEnd   DateTime           @map("period_end") @db.Date
  autoRenew   Boolean            @default(false) @map("auto_renew")
  createdAt   DateTime           @default(now()) @map("created_at")

  vendor      Vendor             @relation(fields: [vendorId], references: [id])
  plan        SubscriptionPlan   @relation(fields: [planId], references: [id])

  @@index([status, periodEnd])
  @@map("vendor_subscriptions")
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  OVERDUE
  SUSPENDED
  CANCELLED
}

model Stall {
  id                BigInt      @id @default(autoincrement())
  vendorId          BigInt      @map("vendor_id")
  name              String      @db.VarChar(255)
  slug              String?     @unique @db.VarChar(255)
  description       String?     @db.Text
  // location stored as lat/lng floats — spatial index via raw SQL
  latitude          Float?
  longitude         Float?
  activationRadius  Int         @default(10) @map("activation_radius")
  status            StallStatus @default(DRAFT)
  priorityWeight    Int         @default(0) @map("priority_weight")
  verifiedByAdminId BigInt?     @map("verified_by_admin_id")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  vendor            Vendor      @relation(fields: [vendorId], references: [id])
  pois              POI[]
  mediaFiles        MediaFile[]

  @@index([vendorId, status])
  @@map("stalls")
}

enum StallStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  HIDDEN
  FORCE_CANCELLED
}

// ─── POI & CONTENT ───────────────────────────────────────────

model POI {
  id               BigInt       @id @default(autoincrement())
  stallId          BigInt?      @map("stall_id")
  name             String       @db.VarChar(255)
  category         String       @db.VarChar(50)
  latitude         Float
  longitude        Float
  activationRadius Int          @default(30) @map("activation_radius")
  isPremiumContent Boolean      @default(false) @map("is_premium_content")
  status           POIStatus    @default(DRAFT)
  sortOrder        Int          @default(0) @map("sort_order")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  stall            Stall?       @relation(fields: [stallId], references: [id])
  contents         POIContent[]
  mediaFiles       MediaFile[]

  @@index([stallId, status])
  @@map("pois")
}

enum POIStatus {
  DRAFT
  ACTIVE
  HIDDEN
}

model POIContent {
  id           BigInt  @id @default(autoincrement())
  poiId        BigInt  @map("poi_id")
  languageCode String  @map("language_code") @db.VarChar(10)
  title        String? @db.VarChar(255)
  ttsScript    String? @map("tts_script") @db.Text
  audioFileUrl String? @map("audio_file_url") @db.VarChar(500)
  duration     Int     @default(0)

  poi          POI     @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@unique([poiId, languageCode])
  @@map("poi_contents")
}

// ─── MEDIA ───────────────────────────────────────────────────

model MediaFile {
  id               BigInt           @id @default(autoincrement())
  vendorId         BigInt?          @map("vendor_id")
  stallId          BigInt?          @map("stall_id")
  poiId            BigInt?          @map("poi_id")
  uploadedById     BigInt?          @map("uploaded_by_id")
  mediaType        MediaType        @map("media_type")
  storagePath      String           @map("storage_path") @db.VarChar(800)
  publicUrl        String           @map("public_url") @db.VarChar(800)
  mimeType         String?          @map("mime_type") @db.VarChar(100)
  sizeBytes        BigInt           @default(0) @map("size_bytes")
  durationSeconds  Int?             @map("duration_seconds")
  width            Int?
  height           Int?
  moderationStatus ModerationStatus @default(PENDING) @map("moderation_status")
  moderatedById    BigInt?          @map("moderated_by_id")
  moderatedAt      DateTime?        @map("moderated_at")
  rejectionReason  String?          @map("rejection_reason") @db.Text
  createdAt        DateTime         @default(now()) @map("created_at")

  vendor           Vendor?          @relation(fields: [vendorId], references: [id])
  stall            Stall?           @relation(fields: [stallId], references: [id])
  poi              POI?             @relation(fields: [poiId], references: [id])
  moderatedBy      User?            @relation("ModeratedBy", fields: [moderatedById], references: [id])

  @@index([vendorId, stallId, mediaType])
  @@index([moderationStatus, createdAt])
  @@map("media_files")
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

// ─── PAYMENTS & REVENUE ──────────────────────────────────────

model Payment {
  id            BigInt        @id @default(autoincrement())
  vendorId      BigInt?       @map("vendor_id")
  stallId       BigInt?       @map("stall_id")
  paymentType   PaymentType   @map("payment_type")
  provider      PaymentProvider
  amount        Decimal       @db.Decimal(14, 2)
  currency      String        @default("VND") @db.VarChar(10)
  status        PaymentStatus @default(PENDING)
  transactionRef String?      @unique @map("transaction_ref") @db.VarChar(255)
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  vendor        Vendor?       @relation(fields: [vendorId], references: [id])

  @@index([vendorId, status, createdAt])
  @@map("payments")
}

enum PaymentType {
  APP_PREMIUM
  VENDOR_MONTHLY
  STALL_PURCHASE
  COMMISSION_PAYOUT
}

enum PaymentProvider {
  MOMO
  VNPAY
  STRIPE
  BANK_QR
  CASH
  MANUAL
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

model CommissionEarning {
  id               BigInt           @id @default(autoincrement())
  vendorId         BigInt           @map("vendor_id")
  commissionRate   Decimal          @map("commission_rate") @db.Decimal(5, 2)
  baseAmount       Decimal          @map("base_amount") @db.Decimal(14, 2)
  commissionAmount Decimal          @map("commission_amount") @db.Decimal(14, 2)
  status           CommissionStatus @default(PENDING)
  createdAt        DateTime         @default(now()) @map("created_at")

  vendor           Vendor           @relation(fields: [vendorId], references: [id])

  @@index([vendorId, status])
  @@map("commission_earnings")
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

// ─── ANALYTICS ───────────────────────────────────────────────

model AnalyticsDailyStall {
  reportDate          DateTime @map("report_date") @db.Date
  stallId             BigInt   @map("stall_id")
  qrScans             Int      @default(0) @map("qr_scans")
  gpsVisits           Int      @default(0) @map("gps_visits")
  freeVisitors        Int      @default(0) @map("free_visitors")
  premiumVisitors     Int      @default(0) @map("premium_visitors")
  audioPlays          Int      @default(0) @map("audio_plays")
  bankQrRevenue       Decimal  @default(0) @map("bank_qr_revenue") @db.Decimal(14, 2)
  cashReportedRevenue Decimal  @default(0) @map("cash_reported_revenue") @db.Decimal(14, 2)
  premiumCommission   Decimal  @default(0) @map("premium_commission") @db.Decimal(14, 2)

  @@id([reportDate, stallId])
  @@map("analytics_daily_stall")
}

// ─── AUDIT LOGS ──────────────────────────────────────────────

model AuditLog {
  id           BigInt   @id @default(autoincrement())
  performedById BigInt? @map("performed_by_id")
  action       String   @db.VarChar(100)
  targetType   String   @map("target_type") @db.VarChar(50) // "vendor", "stall", "media", "poi"
  targetId     BigInt?  @map("target_id")
  targetLabel  String?  @map("target_label") @db.VarChar(255)
  reason       String?  @db.Text
  beforeData   Json?    @map("before_data")
  afterData    Json?    @map("after_data")
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  createdAt    DateTime @default(now()) @map("created_at")

  performedBy  User?    @relation("PerformedBy", fields: [performedById], references: [id])

  @@index([performedById, createdAt])
  @@index([targetType, targetId, createdAt])
  @@map("audit_logs")
}
